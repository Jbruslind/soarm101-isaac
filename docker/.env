# =============================================================================
# Local Stack Configuration
# =============================================================================

# GPU device index (for multi-GPU systems)
NVIDIA_VISIBLE_DEVICES=0

# OpenPi inference endpoint
# Mode A (local):  OPENPI_HOST=openpi-server  OPENPI_PORT=8000
# Mode B (remote): OPENPI_HOST=gpu-server.example.com  OPENPI_PORT=8443
OPENPI_HOST=192.168.8.235
OPENPI_PORT=8443

# Isaac Sim
ACCEPT_EULA=Y
PRIVACY_CONSENT=Y
ISAAC_SIM_HEADLESS=1

# ROS2
ROS_DOMAIN_ID=42
RMW_IMPLEMENTATION=rmw_fastrtps_cpp

# Data paths (relative to docker-compose context)
DATA_DIR=../data
MODELS_DIR=../models
ROBOT_DESC_DIR=../robot_description

# Training defaults (Mode A: local 3080 Ti)
TRAINING_BATCH_SIZE=1
TRAINING_GRAD_ACCUM=8
TRAINING_LORA_RANK=32
TRAINING_QUANTIZE_BASE=true
